POSTGRES_DB=rainbowpaw
POSTGRES_USER=rainbowpaw
POSTGRES_PASSWORD=rainbowpaw
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

CLAW_BOT_TOKEN=
RAINBOW_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=
INTERNAL_TOKEN=dev-secret-token

IDENTITY_SERVICE_URL=http://localhost:3001/api
WALLET_SERVICE_URL=http://localhost:3002/api
BRIDGE_SERVICE_URL=http://localhost:3003/api
REPORT_SERVICE_URL=http://localhost:3004/api

AI_ORCHESTRATOR_SERVICE_URL=http://localhost:3005/api
API_GATEWAY_URL=http://localhost:3012/api
ENABLE_SUPPORT_AI=false
AI_ORCHESTRATOR_HTTP_TIMEOUT_MS=15000
ENABLE_AI_RECOMMEND_ON_PLAY=false

AI_ALERT_MIN_REQUESTS=20
AI_ALERT_ERROR_RATE=0.2
AI_ALERT_FALLBACK_RATE=0.3
AI_ALERT_INTERVAL_MS=300000

AI_MOCK_MODE=true
AI_ENABLE_DB=false
AI_BASE_URL=https://integrate.api.nvidia.com
AI_API_KEY=
AI_MODEL=nvidia/nemotron-3-nano-30b-a3b
AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_EMBEDDINGS_PATH=/v1/embeddings
AI_RERANK_PATH=/v1/ranking
AI_PII_PATH=/v1/extract
AI_RERANK_TOP_N=20
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.2
AI_HTTP_TIMEOUT_MS=60000
AI_RESPONSE_FORMAT=false

# 可选：按岗位覆盖（示例）
# AI_HTTP_TIMEOUT_MS_RECOMMEND_AI=120000
# AI_MAX_TOKENS_RECOMMEND_AI=256
AI_RECOMMEND_TOPK=20
AI_EMBED_BATCH_SIZE=32
AI_ENABLE_PII_REDACTION=true
AI_DAILY_BUDGET_USD=
AI_PRICE_INPUT_PER_1K=
AI_PRICE_OUTPUT_PER_1K=

# NVIDIA build.nvidia.com（OpenAI-兼容）按岗位最终选型（优先 NVIDIA 自家/Free/重点模型）
AI_MODEL_SUPPORT_AI=nvidia/llama-3.1-nemotron-nano-4b-v1.1
AI_MODEL_GROWTH_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_PRODUCT_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_OPS_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_RISK_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_RECOMMEND_AI=nvidia/llama-3.1-nemotron-nano-4b-v1.1

# 推荐系统（下一步接入 embedding/rerank 时使用）
AI_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
AI_RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2
# 备选 rerank（其一）
# AI_RERANK_MODEL=nvidia/llama-3.2-nemoretriever-500m-rerank-v2

# 风控辅助能力（下一步接入 PII 检测时使用）
AI_PII_MODEL=nvidia/gliner-pii

# 视觉/语音（可选，下一步接入）
AI_VL_MODEL=nvidia/nemotron-nano-12b-v2-vl
AI_VOICE_MODEL=nvidia/nemotron-voicechat

# 更强策略模型（可选升级）
AI_MODEL_STRATEGY=nvidia/llama-3.3-nemotron-super-49b-v1.5
# AI_MODEL_STRATEGY=nvidia/nemotron-3-super-120b-a12b
