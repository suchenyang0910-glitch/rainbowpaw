POSTGRES_DB=rainbowpaw
POSTGRES_USER=rainbowpaw
POSTGRES_PASSWORD=rainbowpaw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

INTERNAL_TOKEN=change-me

CLAW_BOT_TOKEN=
RAINBOW_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=

AI_MOCK_MODE=false
AI_BASE_URL=https://integrate.api.nvidia.com
AI_API_KEY=

AI_MODEL=nvidia/nemotron-3-nano-30b-a3b
AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_EMBEDDINGS_PATH=/v1/embeddings
AI_RERANK_PATH=/v1/ranking
AI_PII_PATH=/v1/extract

AI_MODEL_SUPPORT_AI=nvidia/llama-3.1-nemotron-nano-4b-v1.1
AI_MODEL_GROWTH_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_PRODUCT_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_OPS_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_RISK_AI=nvidia/nemotron-3-nano-30b-a3b
AI_MODEL_RECOMMEND_AI=nvidia/llama-3.1-nemotron-nano-4b-v1.1

AI_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
AI_RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2
AI_PII_MODEL=nvidia/gliner-pii
AI_VL_MODEL=
AI_VOICE_MODEL=

AI_RERANK_TOP_N=20
AI_RECOMMEND_TOPK=20
AI_EMBED_BATCH_SIZE=32
AI_ENABLE_PII_REDACTION=true

AI_HTTP_TIMEOUT_MS=60000
AI_RESPONSE_FORMAT=false

# 可选：按岗位覆盖（示例）
# AI_HTTP_TIMEOUT_MS_RECOMMEND_AI=120000
# AI_MAX_TOKENS_RECOMMEND_AI=256
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.2
AI_DAILY_BUDGET_USD=
AI_PRICE_INPUT_PER_1K=
AI_PRICE_OUTPUT_PER_1K=

ENABLE_AI_RECOMMEND_ON_PLAY=false
ENABLE_SUPPORT_AI=false
PUBLIC_WEB_BASE_URL=https://your-domain.com
SUPPORT_LINK=https://t.me/RainbowPawbot

VITE_API_BASE_URL=https://your-domain.com
VITE_SUPPORT_LINK=https://t.me/RainbowPawbot
VITE_DEV_TELEGRAM_ID=
VITE_MOCK_INIT_DATA=

# HTTPS（可选：使用 deploy/docker-compose.server.tls.yml）
DOMAIN=your-domain.com
